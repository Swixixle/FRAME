ANTHROPIC_API_KEY=
# Optional. YouTube transcript fallback when timedtext is blocked (https://supadata.ai)
SUPADATA_API_KEY=
ASSEMBLYAI_API_KEY=
FEC_API_KEY=
# Congress.gov API (https://api.congress.gov/sign-up/)
CONGRESS_API_KEY=
OPENSECRETS_API_KEY=
# ─── News sources ───────────────────────────────────────────
# GDELT is used first and requires no key.
# NewsAPI runs only if GDELT returns no articles. Free tier: 100 requests/day —
# https://newsapi.org/register
NEWSAPI_KEY=
SOCIALBLADE_API_KEY=
DATABASE_URL=
REDIS_URL=
# ─── Cron (drift snapshots) ─────────────────────────────────
# Same value on the web service and the Render cron job. curl sends: x-cron-secret
CRON_SECRET=
# Optional override for local testing; Render cron uses FRAME_CRON_DRIFT_URL in render.yaml
# FRAME_CRON_DRIFT_URL=https://your-service.onrender.com/v1/cron/drift
FRAME_WHISPER_CACHE=
# Optional Claude model overrides (defaults in dossier/assemble.py)
CLAUDE_SONNET_MODEL=
CLAUDE_OPUS_MODEL=
# ─── Legal records (CourtListener) ─────────────────────────
# Public opinion search works without a key; a token raises rate limits.
# Register: https://www.courtlistener.com/register/
# API help: https://www.courtlistener.com/help/api/
COURTLISTENER_API_KEY=
# EthicalAlt proportionality API (https://ethicalalt-api.onrender.com or http://localhost:3001 for local)
PROPORTIONALITY_API_URL=https://ethicalalt-api.onrender.com
# Podcast / upload investigative pipeline (off by default for slim PUBLIC EYE)
PUBLIC_EYE_PODCAST_ENABLED=
# GovInfo API (https://www.govinfo.gov/api-signup)
GOVINFO_API_KEY=
# SEC EDGAR (recommended: descriptive User-Agent with contact email per sec.gov webmaster FAQ)
SEC_EDGAR_USER_AGENT=
